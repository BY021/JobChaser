datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  role       String    @default("user")
  createdJobs Job[]    @relation("CreatedJobs") 
  savedJobs   Job[]    @relation("SavedJobs") 
  createdAt  DateTime  @default(now())
}

model Job {
  id          Int       @id @default(autoincrement())
  company     String
  logo        String
  position    String
  role        String
  level       String
  postedAt    DateTime
  contract    String
  location    String
  languages   Json?
  tools       Json?
  createdBy   User      @relation("CreatedJobs", fields: [createdById], references: [id])
  createdById Int
  savedBy     User[]    @relation("SavedJobs") 
  createdAt   DateTime  @default(now())
}